# Oracle HCM Cloud REST API — connection settings
#
# Copy this file to `.env` in the repo root and fill in real values.
# NEVER commit `.env` to git — it is listed in .gitignore.

# Base URL of your Oracle Fusion pod (no trailing slash).
# Replace this placeholder with your own pod URL before running any example.
HCM_BASE_URL=https://your-fusion-pod.oraclecloud.com

# REST API version (leave as-is unless Oracle has rolled forward)
HCM_API_VERSION=11.13.18.05

# Credentials for an HCM user with REST API access
HCM_USERNAME=your_username_here
HCM_PASSWORD=your_password_here

# Request timeout in seconds
HCM_TIMEOUT=30

# Verify TLS certificates (set to "false" only for local debugging)
HCM_VERIFY_SSL=true
